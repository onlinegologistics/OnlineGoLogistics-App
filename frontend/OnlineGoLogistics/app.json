{
  "expo": {
    "name": "OnlineGoLogistics",
    "slug": "OnlineGoLogistics",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "onlinegologistics",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.sakhee.onlinegologistics",
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "INTERNET"
      ],
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "splash": {
        "image": "./assets/images/transparent.png",
        "resizeMode": "contain",
        "backgroundColor": "#0B1528",
        "dark": {
          "backgroundColor": "#0B1528"
        }
      },
      "package": "com.onlinegologistics",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1528",
          "dark": {
            "backgroundColor": "#0B1528"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "APP_VARIANT": "preview",
      "router": {},
      "eas": {
        "projectId": "228e5506-2daf-4635-850f-cd16326b6103"
      },
      "API_URL": "https://app.onlinegologistics.in"
    }
  }
}
