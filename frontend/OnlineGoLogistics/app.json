{
  "expo": {
    "name": "OnlineGoLogistics",
    "slug": "OnlineGoLogistics",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "onlinegologistics",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.sakhee.onlinegologistics",
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "INTERNET"
      ],
      "versionCode": 2,
      "package": "com.onlinegologistics"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "APP_VARIANT": "preview",
      "router": {},
      "eas": {
        "projectId": "228e5506-2daf-4635-850f-cd16326b6103"
      },
      "API_URL": "https://onlinegologistics-api.onrender.com"
    }
  }
}
